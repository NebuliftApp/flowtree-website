---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProductMedia from '../components/ProductMedia.astro';
import CTA from '../components/CTA.astro';

const base = import.meta.env.BASE_URL;
---

<Layout>
  <Navbar />
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">AI-assisted development for macOS</p>
          <h1>Keep every coding task <span class="gradient-text">in context.</span></h1>
          <p class="lede">FlowTree keeps each branch with its terminals, AI sessions, Git changes, and IDE access—so you can move between tasks without reconstructing what was happening.</p>
          <div class="button-row">
            <a class="button button-primary" href={`${base}features/`}>Explore FlowTree →</a>
            <a class="button button-secondary" href={`${base}download/`}>Release status</a>
          </div>
          <div class="trust-row" aria-label="Product attributes">
            <span class="trust-pill">Native macOS app</span>
            <span class="trust-pill">Local-first</span>
            <span class="trust-pill">Works with your AI CLI</span>
          </div>
        </div>
        <ProductMedia
          kind="image"
          src="images/flowtree-hero.png"
          alt="FlowTree showing several worktrees, each with its own workflow state and terminal sessions."
          ratio="app"
          width={1444}
          height={925}
          eager
        />
      </div>
    </section>

    <section class="section section-border">
      <div class="narrow">
        <div class="section-heading center">
          <p class="eyebrow">The problem</p>
          <h2>AI work rarely stays in one window.</h2>
          <p>One model is building, another is reviewing, a shell is running tests, and Git shows what actually changed. Add a second task and the windows stop telling you which work they belong to.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-heading center">
          <p class="eyebrow">Context organised by task</p>
          <h2>Everything around the branch stays together.</h2>
        </div>
        <div class="card-grid">
          <article class="feature-card">
            <div class="feature-icon">⑂</div>
            <h3>One home for each task</h3>
            <p>Give every feature, fix, or review its own worktree without disturbing work already in progress.</p>
          </article>
          <article class="feature-card">
            <div class="feature-icon mint">›_</div>
            <h3>Clear roles for every model</h3>
            <p>Use one agent to build, another to challenge the result, and separate sessions for tests and logs.</p>
          </article>
          <article class="feature-card">
            <div class="feature-icon amber">↩</div>
            <h3>Ready when you return</h3>
            <p>Persistent terminals and visible workflow states make it easy to resume the right task.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section section-border">
      <div class="container split">
        <div class="split-copy">
          <p class="eyebrow">Worktree-first</p>
          <h2>Create the workspace. Start the right tools.</h2>
          <p class="lede">Create or import a worktree, launch your chosen AI or shell profile, and open the same files in your IDE. The branch stays isolated; its working context stays easy to find.</p>
          <ul class="check-list">
            <li>Create worktrees from new, local, or remote branches.</li>
            <li>Keep multiple terminal sessions with each worktree.</li>
            <li>Organise work with your own names and workflow states.</li>
          </ul>
          <div class="button-row"><a class="text-link" href={`${base}worktrees/`}>See the worktree workflow →</a></div>
        </div>
        <ProductMedia
          kind="video"
          src="images/homepage-worktree-creation.mp4"
          poster="images/homepage-worktree-creation-poster.png"
          alt="Creating a worktree and starting a dedicated AI terminal session."
          ratio="app"
        />
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-heading center">
          <p class="eyebrow">Finish in the same context</p>
          <h2>Review what changed. Then ship it.</h2>
          <p>Inspect diffs, stage precise changes, commit, push, merge, rebase, and work through conflicts without reaching for a separate Git client.</p>
        </div>
        <div class="button-row" style="justify-content:center">
          <a class="button button-secondary" href={`${base}features/`}>See all core features</a>
          <a class="button button-secondary" href={`${base}how-it-works/`}>How local-first works</a>
        </div>
      </div>
    </section>

    <CTA title="Keep the work. Lose the window tangle." description="FlowTree is coming to macOS. See the current release status and requirements." />
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'FlowTree',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'macOS 26 or later',
    description: 'A native macOS workspace that keeps Git worktrees, AI coding sessions, terminals, and code review together by task.',
  })} />
</Layout>

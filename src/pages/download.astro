---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="FlowTree for macOS — release status" description="FlowTree is not available to download yet. Check the current release status and requirements.">
  <Navbar />
  <main>
    <PageHero eyebrow="Release status" title="FlowTree is coming to macOS." description="The public build is not ready yet. Download and installation details will appear here at release." />

    <section class="section-tight">
      <div class="status-card">
        <span class="status-badge">Pre-release</span>
        <h2>Current requirements</h2>
        <p class="lede">macOS 26 or later, a local Git installation, and tmux for persistent terminals.</p>
        <div class="button-row" style="justify-content:center"><a class="button button-secondary" href={`${base}features/`}>Explore FlowTree</a><a class="button button-secondary" href={`${base}faq/`}>Read the FAQ</a></div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Pricing — FlowTree" description="FlowTree pricing will be published before release.">
  <Navbar />
  <main>
    <PageHero eyebrow="Pricing" title="Pricing has not been announced." description="FlowTree is not for sale yet. The complete price, licence terms, and any trial details will be published here before release." />

    <section class="section-tight">
      <div class="status-card">
        <span class="status-badge">Pre-release</span>
        <h2>No checkout yet</h2>
        <p class="lede">No payment or subscription is being collected from this website.</p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

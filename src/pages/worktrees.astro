---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import ProductMedia from '../components/ProductMedia.astro';
import CTA from '../components/CTA.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Git worktree management for macOS — FlowTree" description="Give every branch its own files, terminals, AI sessions, workflow state, and review flow.">
  <Navbar />
  <main>
    <PageHero eyebrow="Worktrees" title="A complete workspace for every task." description="Keep features, fixes, experiments, and reviews open side by side without disturbing one another.">
      <div class="button-row"><a class="button button-primary" href="#workflow">See the workflow ↓</a><a class="button button-secondary" href={`${base}features/`}>All features</a></div>
    </PageHero>

    <section class="section-tight">
      <div class="container">
        <ProductMedia kind="image" src="images/flowtree-hero.png" alt="FlowTree showing worktrees organised by workflow state." ratio="app" width={1444} height={925} />
      </div>
    </section>

    <section id="workflow" class="section section-border">
      <div class="container">
        <div class="section-heading center"><p class="eyebrow">One simple flow</p><h2>Create. Work. Review.</h2></div>
        <div class="workflow-grid">
          <article class="workflow-step"><h3>Create or import</h3><p>Start from a new, local, or remote branch—or bring in a worktree already on disk.</p></article>
          <article class="workflow-step"><h3>Work in context</h3><p>Launch AI tools, shells, tests, and your IDE in the correct directory.</p></article>
          <article class="workflow-step"><h3>Review and ship</h3><p>Inspect changes, commit, push, merge, or rebase, then remove the worktree when it is done.</p></article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container card-grid two">
        <article class="card"><div class="feature-icon">✓</div><h3>Ready to use</h3><p>New worktrees can carry forward useful untracked setup files while leaving generated output behind.</p></article>
        <article class="card"><div class="feature-icon mint">▦</div><h3>Easy to find again</h3><p>Use custom states, names, and colours to see what is active, blocked, ready for review, or finished.</p></article>
      </div>
    </section>
    <CTA title="Give every task room to run." />
  </main>
  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTA from '../components/CTA.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="How FlowTree works — local Git, terminals, and files" description="FlowTree coordinates the Git, terminals, files, and AI tools already on your Mac.">
  <Navbar />
  <main>
    <PageHero eyebrow="How it works" title="Your tools, organised around the work." description="FlowTree uses ordinary local repositories and processes. It adds a native workspace around them." />

    <section class="section-tight">
      <div class="container">
        <div class="architecture" aria-label="FlowTree local architecture">
          <div class="architecture-node primary"><div><strong>FlowTree</strong><span>Worktrees · review · workflow</span></div></div>
          <div class="architecture-arrow" aria-hidden="true">→</div>
          <div class="architecture-node"><div><strong>Local tools</strong><span>Git · tmux · shell · AI CLIs</span></div></div>
          <div class="architecture-arrow" aria-hidden="true">→</div>
          <div class="architecture-node"><div><strong>Your Mac</strong><span>Repositories · files · app data</span></div></div>
        </div>
      </div>
    </section>

    <section class="section section-border">
      <div class="container card-grid">
        <article class="card"><div class="feature-icon">⑂</div><h3>Normal Git worktrees</h3><p>FlowTree creates and manages standard worktrees that remain usable from other tools.</p></article>
        <article class="card"><div class="feature-icon mint">›_</div><h3>Persistent local terminals</h3><p>A dedicated tmux server keeps terminal sessions available when you return.</p></article>
        <article class="card"><div class="feature-icon purple">⌂</div><h3>Local application state</h3><p>Project settings, terminal metadata, and review state remain on your Mac.</p></article>
      </div>
    </section>

    <section id="networking" class="section">
      <div class="narrow">
        <div class="split-copy">
          <p class="eyebrow">Local-first</p>
          <h2>No FlowTree cloud between you and your code.</h2>
          <p class="lede">FlowTree does not upload repositories to its own service. Remote Git commands still contact the remote you configured, and AI CLIs follow their own provider policies.</p>
          <ul class="check-list">
            <li>Local work uses your files and Git installation.</li>
            <li>Remote operations use your existing Git authentication.</li>
            <li>FlowTree does not require a repository-hosting account.</li>
          </ul>
          <div class="button-row"><a class="text-link" href={`${base}privacy/`}>Read the privacy summary →</a></div>
        </div>
      </div>
    </section>

    <section class="section section-border">
      <div class="container">
        <div class="section-heading center"><p class="eyebrow">Requirements</p><h2>What FlowTree uses.</h2></div>
        <div class="card-grid">
          <article class="card"><h3>macOS 26+</h3><p>The current application target.</p></article>
          <article class="card"><h3>Git</h3><p>Your trusted local Git executable.</p></article>
          <article class="card"><h3>tmux</h3><p>Required for persistent embedded terminals.</p></article>
        </div>
      </div>
    </section>
    <CTA />
  </main>
  <Footer />
</Layout>

---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const base = import.meta.env.BASE_URL;
const {
  title = 'FlowTree — Keep every coding task in context',
  description = 'A native macOS workspace that keeps Git worktrees, AI coding sessions, terminals, and code review together by task.',
  image = `${base}images/app-full.png`,
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const socialImage = Astro.site ? new URL(image, Astro.site) : image;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0c11" />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="FlowTree" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

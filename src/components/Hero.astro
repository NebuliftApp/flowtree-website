---
// Hero section — factual intro with real app screenshot
---

<section class="relative pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] pointer-events-none">
    <div class="absolute top-20 left-1/4 w-96 h-96 bg-accent/8 rounded-full blur-[120px]"></div>
    <div class="absolute top-40 right-1/4 w-80 h-80 bg-cyan/6 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-bg-surface/60 backdrop-blur-sm mb-8 animate-on-scroll">
      <span class="w-2 h-2 rounded-full bg-green"></span>
      <span class="text-sm text-text-secondary">Native macOS App · Swift & SwiftUI</span>
    </div>

    <h1 class="text-5xl md:text-7xl font-extrabold leading-[1.08] tracking-tight mb-6 animate-on-scroll delay-1">
      FlowTree
    </h1>

    <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-4 leading-relaxed animate-on-scroll delay-2">
      A worktree-first Git workspace for macOS.
    </p>
    <p class="text-base text-text-muted max-w-xl mx-auto mb-10 leading-relaxed animate-on-scroll delay-2">
      Keep every branch in its own live environment — with its own terminal tabs, branch context, 
      and review workflow. Manage worktrees, branches, history, and Git operations from one interface.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20 animate-on-scroll delay-3">
      <a href="#features" class="inline-flex items-center gap-2 px-8 py-3.5 bg-accent hover:bg-accent-hover text-bg font-semibold rounded-xl transition-all hover:shadow-[0_0_30px_rgba(91,143,249,0.3)]">
        See What It Does
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19" />
          <polyline points="19 12 12 19 5 12" />
        </svg>
      </a>
    </div>

    <!-- Real app screenshot -->
    <div class="relative max-w-5xl mx-auto animate-on-scroll delay-4">
      <div class="absolute inset-0 bg-gradient-to-t from-accent/8 via-cyan/4 to-transparent rounded-2xl blur-2xl scale-105"></div>
      <div class="relative rounded-2xl border border-border overflow-hidden shadow-2xl shadow-black/40">
        <img 
          src="/images/app-full.png" 
          alt="FlowTree showing a worktree with an integrated terminal session" 
          class="w-full h-auto"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

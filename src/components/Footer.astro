---
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="brand" href={base}>
          <img src={`${base}images/app-icon.png`} alt="" />
          <span>FlowTree</span>
        </a>
        <p>Keep branches, AI sessions, terminals, and Git changes together by task.</p>
      </div>
      <div class="footer-column">
        <strong>Product</strong>
        <a href={`${base}features/`}>Features</a>
        <a href={`${base}worktrees/`}>Worktrees</a>
        <a href={`${base}pricing/`}>Pricing</a>
        <a href={`${base}download/`}>Release status</a>
      </div>
      <div class="footer-column">
        <strong>Learn</strong>
        <a href={`${base}how-it-works/`}>How it works</a>
        <a href={`${base}faq/`}>FAQ</a>
      </div>
      <div class="footer-column">
        <strong>Trust</strong>
        <a href={`${base}privacy/`}>Privacy</a>
        <a href={`${base}how-it-works/#networking`}>Networking</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} FlowTree. All rights reserved.</span>
      <span>Native for macOS · Local-first</span>
    </div>
  </div>
</footer>

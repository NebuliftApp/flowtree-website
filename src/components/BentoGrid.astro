---
// Additional capabilities grid — factual descriptions from the product brief
const features = [
  {
    title: 'Review & Commit',
    description: 'Full-screen review mode with unified or split diffs. Stage, unstage, or discard changes at file, hunk, or selected-line level. Write commit messages in-app with recent message history.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><rect x="2" y="6" width="8" height="12" rx="1"/><rect x="14" y="6" width="8" height="12" rx="1"/></svg>`,
    color: 'green',
    span: 'md:col-span-2',
    screenshot: '/images/review.png',
    placeholder: null,
  },
  {
    title: 'Merge Preview',
    description: 'Preview merges before running them. See fast-forward detection, ahead/behind analysis, conflict detection, and conflicting file lists. Auto-stash dirty worktree changes before merge when needed.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>`,
    color: 'orange',
    span: '',
    screenshot: '/images/merge-preview.png',
    placeholder: null,
  },
  {
    title: 'Commit History',
    description: 'Searchable commit graph for the whole project. History loads incrementally so large repositories stay usable. HEAD and branch decorations are highlighted.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="4" cy="6" r="2"/><circle cx="20" cy="18" r="2"/><path d="M6 7.5L9.5 10.5"/><path d="M14.5 13.5L18 16.5"/></svg>`,
    color: 'accent',
    span: '',
    screenshot: '/images/history-tab.png',
    placeholder: null,
  },
  {
    title: 'Protected Branches',
    description: 'Mark critical branches as protected from Settings. Protected branches cannot be pushed to, committed to, or have their remote branch deleted from FlowTree.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    color: 'red',
    span: '',
    screenshot: '/images/branch-safety.png',
    placeholder: null,
  },
  {
    title: 'Git Operations',
    description: 'Pull, push, and fetch from each worktree. Merge branches with auto-stash when the target is dirty. Manage stashes: create, pop, apply, drop, and inspect file contents.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>`,
    color: 'cyan',
    span: '',
    screenshot: null,
    placeholder: null,
  },
  {
    title: 'Background Sync',
    description: 'Automatic background sync on a timer with manual refresh on demand. A sync activity view shows current steps, recent history, timing, and errors. Cached state keeps the UI responsive between syncs.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/></svg>`,
    color: 'purple',
    span: '',
    screenshot: null,
    placeholder: null,
  },
  {
    title: 'GitHub Authentication',
    description: 'Connect a GitHub account through device-flow authentication. Credentials are stored in macOS Keychain.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
    color: 'text-primary',
    span: '',
    screenshot: null,
    placeholder: null,
  },
  {
    title: 'Open In Your IDE',
    description: 'Open any worktree directly in Finder, Android Studio, or IntelliJ with one click. Pop a worktree into its own window for focused work.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
    color: 'accent',
    span: '',
    screenshot: null,
    placeholder: null,
  },
];
---

<section class="py-20 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">More Capabilities</h2>
      <p class="text-text-secondary text-lg max-w-xl mx-auto">
        Git operations, review workflows, safety features, and integrations — all built into the same workspace.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-4">
      {features.map((feature, i) => (
        <div class={`animate-on-scroll delay-${(i % 5) + 1} group rounded-2xl border border-border bg-bg-surface overflow-hidden hover:border-${feature.color}/30 transition-all duration-300 ${feature.span}`}>
          {feature.screenshot ? (
            <div class={`border-b border-border overflow-hidden ${feature.span ? '' : 'max-h-[280px]'}`}>
              <img 
                src={feature.screenshot} 
                alt={feature.title} 
                class="w-full h-auto"
                loading="lazy"
              />
            </div>
          ) : null}
          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class={`w-9 h-9 rounded-lg bg-${feature.color}/10 flex items-center justify-center text-${feature.color}`}>
                <Fragment set:html={feature.icon} />
              </div>
              <h3 class="text-base font-semibold">{feature.title}</h3>
            </div>
            <p class="text-sm text-text-secondary leading-relaxed">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
// How FlowTree works — architectural overview for a technical audience
const layers = [
  {
    label: 'FlowTree UI',
    sublabel: 'Native SwiftUI interface',
    color: 'accent',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  },
  {
    label: 'Git Command Runner',
    sublabel: 'Async process execution with retry logic',
    color: 'cyan',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
  },
  {
    label: '/usr/bin/git',
    sublabel: 'Your system git — nothing custom',
    color: 'orange',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><line x1="1.05" y1="12" x2="7" y2="12"/><line x1="17.01" y1="12" x2="22.96" y2="12"/></svg>`,
  },
];

const details = [
  {
    title: 'Local git CLI, not a custom implementation',
    description: 'Every git operation — commits, branches, worktrees, merges, stashes — runs through your system\'s own /usr/bin/git. No embedded git library, no reimplementation. What FlowTree does is what git does.',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
  },
  {
    title: 'Nothing leaves your machine',
    description: 'Repositories, worktrees, branches, commit history, and app state all stay on your local disk. FlowTree stores its database in ~/Library/Application Support/ and credentials in macOS Keychain. There is no cloud sync, no telemetry, and no FlowTree server.',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: 'Real-time file watching',
    description: 'FlowTree monitors your worktree directories using macOS FSEvents. When files change on disk — from your editor, terminal, or AI tool — the UI updates automatically without polling.',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
  {
    title: 'SQLite for app state, Keychain for credentials',
    description: 'Project configuration, cached branch data, terminal sessions, and sync state are persisted in a local SQLite database. GitHub credentials, when used, are stored in macOS Keychain — encrypted by the OS, not by FlowTree.',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
  },
  {
    title: 'Terminals backed by tmux',
    description: 'Built-in terminals run on a dedicated tmux server separate from your own tmux config. Sessions persist across app restarts. The terminal itself is rendered using Ghostty\'s rendering engine for a native experience.',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8l4 4-4 4"/><line x1="12" y1="16" x2="18" y2="16"/></svg>`,
  },
  {
    title: 'GitHub auth is optional',
    description: 'FlowTree works fully offline with local repositories. GitHub device-flow authentication is available for remote operations but is entirely optional — no account required to use the app.',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  },
];
---

<section id="how-it-works" class="py-20 md:py-32 border-t border-border">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">How It Works</h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        FlowTree is a native UI layer over your local git installation. It doesn't replace git or reimplement it — it runs your system's git CLI and presents the results.
      </p>
    </div>

    <!-- Architecture flow -->
    <div class="max-w-md mx-auto mb-16 animate-on-scroll delay-1">
      <div class="flex flex-col items-center gap-0">
        {layers.map((layer, i) => (
          <div class="w-full">
            <div class={`relative border border-${layer.color}/30 bg-${layer.color}/5 rounded-xl px-6 py-4 flex items-center gap-4`}>
              <div class={`w-10 h-10 rounded-lg bg-${layer.color}/10 flex items-center justify-center text-${layer.color} shrink-0`}>
                <Fragment set:html={layer.icon} />
              </div>
              <div>
                <p class="font-semibold text-sm">{layer.label}</p>
                <p class="text-xs text-text-muted">{layer.sublabel}</p>
              </div>
            </div>
            {i < layers.length - 1 && (
              <div class="flex justify-center py-1.5">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Detail cards -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {details.map((detail, i) => (
        <div class={`animate-on-scroll delay-${(i % 5) + 1} rounded-2xl border border-border bg-bg-surface p-6 hover:border-accent/20 transition-colors duration-300`}>
          <div class="flex items-start gap-3 mb-3">
            <div class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center text-accent shrink-0 mt-0.5">
              <Fragment set:html={detail.icon} />
            </div>
            <h3 class="text-sm font-semibold leading-snug">{detail.title}</h3>
          </div>
          <p class="text-sm text-text-secondary leading-relaxed">{detail.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}
const { eyebrow, title, description } = Astro.props;
---

<header class="page-hero">
  <div class="container">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="lede">{description}</p>
    <slot />
  </div>
</header>

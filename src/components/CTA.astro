---
const base = import.meta.env.BASE_URL;
interface Props { title?: string; description?: string; }
const {
  title = 'Keep every task in context.',
  description = 'FlowTree is coming to macOS. See the current release status and requirements.',
} = Astro.props;
---

<section class="section section-border">
  <div class="container">
    <div class="cta-panel">
      <div>
        <p class="eyebrow">Coming to macOS</p>
        <h2>{title}</h2>
        <p>{description}</p>
      </div>
      <div class="button-row">
        <a class="button button-primary" href={`${base}download/`}>Release status →</a>
      </div>
    </div>
  </div>
</section>

---
interface Props {
  kind?: 'image' | 'video';
  src: string;
  alt: string;
  poster?: string;
  ratio?: 'wide' | 'app' | 'square';
  width?: number;
  height?: number;
  eager?: boolean;
}

const {
  kind = 'image',
  src,
  alt,
  poster,
  ratio = 'wide',
  width,
  height,
  eager = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const assetUrl = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
---

<figure class={`product-media ratio-${ratio}`}>
  {kind === 'video' ? (
    <video
      aria-label={alt}
      autoplay
      controls
      loop
      muted
      playsinline
      preload="metadata"
      poster={poster ? assetUrl(poster) : undefined}
    >
      <source src={assetUrl(src)} type="video/mp4" />
    </video>
  ) : (
    <img
      src={assetUrl(src)}
      alt={alt}
      width={width}
      height={height}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={eager ? 'high' : 'auto'}
    />
  )}
</figure>

---
interface Props {
  kind?: 'screenshot' | 'video' | 'diagram';
  title: string;
  description: string;
  ratio?: 'wide' | 'app' | 'square';
}

const { kind = 'screenshot', title, description, ratio = 'wide' } = Astro.props;
const labels = { screenshot: 'Screenshot placeholder', video: 'Video placeholder', diagram: 'Diagram placeholder' };
---

<div class={`media-placeholder ratio-${ratio}`} data-media-placeholder={kind} role="img" aria-label={`${labels[kind]}: ${title}. ${description}`}>
  <div class="placeholder-chrome" aria-hidden="true"><i></i><i></i><i></i></div>
  <div class="placeholder-copy">
    <div class="placeholder-icon" aria-hidden="true">
      {kind === 'video' ? <span class="play-ring">▶</span> : kind === 'diagram' ? '↳' : '▧'}
    </div>
    <div class="placeholder-label">{labels[kind]}</div>
    <strong>{title}</strong>
    <p>{description}</p>
  </div>
</div>
